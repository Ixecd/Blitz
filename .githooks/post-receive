#!/bin/bash
# KubePivot GitOps Hook — post-receive
#
# git push → 自动触发 kp deploy --changed-only
# 安装：make tools（自动注册到 .git/hooks/）
#
# ⚠️  前置条件（在 Git 服务器上配置，不要提交到仓库）：
#   1. kubeconfig 文件放在服务器本地，不要上传 Git
#      export KUBECONFIG=/home/git/.kube/config
#   2. kube context 提前配好，指向目标集群
#      kubectl config use-context <your-context>
#   3. kp 二进制安装在服务器上
#      go install github.com/Ixecd/kubepivot/cmd/kp@latest
#
# 本地开发时此 hook 不会触发（post-receive 只在服务端执行）
# 本地可用 pre-push hook 跑测试

set -e

echo "🚀 [KubePivot] git push detected, triggering deploy..."

# 可在此覆盖 kubeconfig/context（不要硬编码敏感信息）
# export KUBECONFIG=/home/git/.kube/config

kp deploy --changed-only

echo "✅ [KubePivot] deploy complete"
